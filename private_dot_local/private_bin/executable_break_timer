# break_timer — yambar script-module producer + break notifier.
# Eye break every 20 min (20-20-20); every 3rd is a movement break.
# The countdown stops while a break notification is up; dismissing
# it starts the next countdown.
#   SIGUSR1: pause/resume toggle (keybind)
#   SIGUSR2: reset the whole cycle (lock wrapper, on unlock)
#   SIGRTMIN / SIGRTMIN+1: explicit pause / resume (lock wrapper)
set -u

INTERVAL=${BREAK_INTERVAL:-$((20 * 60))}
MOVE_EVERY=${BREAK_MOVE_EVERY:-3}

remaining=$INTERVAL
fired=0
paused=0
last=            # last-emitted display state; emit only on change

trap 'paused=$((1 - paused))' USR1
trap 'remaining=$INTERVAL; fired=0' USR2   # full reset: back to eye > eye > walk
trap 'paused=1' RTMIN
trap 'paused=0' RTMIN+1

fmt_next() { # minutes (rounded up) above a minute, seconds below
    if [ "$remaining" -ge 60 ]; then
        printf '%dm' $(( (remaining + 59) / 60 ))
    else
        printf '%ds' "$remaining"
    fi
}

emit() { # $1: countdown | break — lets the bar render the break state
    printf 'next|string|%s\n' "$(fmt_next)"
    printf 'kind|string|%s\n' "$kind"
    printf 'state|string|%s\n' "$1"
    printf 'paused|bool|%s\n\n' "$([ "$paused" -eq 1 ] && echo true || echo false)"
}

while :; do
    kind=eyes
    [ $(( (fired + 1) % MOVE_EVERY )) -eq 0 ] && kind=move

    now="$(fmt_next)|$kind|$paused"
    if [ "$now" != "$last" ]; then
        emit countdown
        last=$now
    fi

    sleep 1 & wait $!
    [ "$paused" -eq 1 ] && continue

    remaining=$((remaining - 1))
    [ "$remaining" -gt 0 ] && continue

    fired=$((fired + 1))
    emit break
    if [ "$kind" = move ]; then
        notify-send --wait -u critical -a break_timer \
            -h string:bgcolor:#3a1f1f "🚶 Movement break" \
            "Stand up, stretch, walk about for 5 minutes." &
    else
        notify-send --wait -u critical -a break_timer \
            -h string:bgcolor:#3a1f1f "👀 Eye break" \
            "Look at something ~6 m away for 20 seconds." &
    fi
    wait $!          # ← the pause: returns when you dismiss
    remaining=$INTERVAL
    last=            # force a redraw for the fresh countdown
done
